# ===== Feishu =====
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_CHAT_ID=oc_xxx
FEISHU_BOT_OPEN_ID=ou_xxx
FEISHU_OWNER_OPEN_ID=ou_xxx

# ===== DeepSeek =====
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== Ollama (optional, for embeddings) =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# ===== GitHub =====
GH_USERNAME=your_username
GH_TOKEN=ghp_xxx
GH_PRIVATE_REPOS=owner/repo1,owner/repo2

# ===== Profile =====
PROFILE_ID=default
PROFILES_DIR=.

# ===== Behavior =====
DRY_RUN=true
# 流式回复走飞书 CardKit 流式卡片接口，需在应用后台开通 cardkit:card:write 权限；
# 未开通时自动降级为「发文本消息 + 编辑」
STREAMING_REPLY_ENABLED=true
STREAMING_REPLY_UPDATE_INTERVAL_SECONDS=0.35
MEMORY_ENABLED=true
MEMORY_CONFIRMATION_ENABLED=true
# 可选：OceanBase/MySQL 记忆后端。支持 jdbc:mysql://127.0.0.1:2881/shuye_chat 这种写法；
# 不配置时继续使用 memory_data/<PROFILE_ID>/memories.json
MEMORY_DATABASE_DSN=
# 是否把 shuye_message_chunks 作为只读聊天归档记忆参与检索
MEMORY_INCLUDE_CHAT_ARCHIVE=false
# 聊天归档可见性：owner_only / public_to_target / private
MEMORY_CHAT_ARCHIVE_VISIBILITY=owner_only

# ===== Polling =====
POLL_INTERVAL_SECONDS=300
