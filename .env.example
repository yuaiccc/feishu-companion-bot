# ===== Profile（开源复用时先改这里）=====
# profiles/default.json 是通用模板；复制 profiles/example-couple.json 可创建关系陪伴模板。
PROFILE_ID=default

# ===== DeepSeek =====
DEEPSEEK_API_KEY=your-deepseek-api-key
# 可选，默认 https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选，默认 deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat

# ===== Feishu Webhook（发消息）=====
FEISHU_WEBHOOK_URL=your-feishu-webhook-url

# ===== Feishu 自建应用 OpenAPI（读消息、表情回复）=====
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-app-secret
FEISHU_SHUSHU_OPEN_ID=ou_target_xxx
FEISHU_SANGE_OPEN_ID=ou_owner_xxx
# Actions 通过消息列表 REST API 兜底时，需要这个 open_id 精确判断是否 @ 机器人
FEISHU_BOT_OPEN_ID=ou_bot_xxx
# 可选：无法拿到 bot open_id 时才用显示名兜底，不如 open_id 稳定
# FEISHU_BOT_NAME=CompanionBot
FEISHU_CHAT_ID=oc_xxx
# 可选：owner 和机器人的单聊 chat_id；本地服务启动、重启、异常时推送状态
FEISHU_STATUS_CHAT_ID=oc_p2p_xxx
FEISHU_READ_MESSAGES=true
# 长连接补发太旧的事件直接跳过，避免回复已撤回/过期消息
FEISHU_EVENT_MAX_AGE_SECONDS=600

# ===== 记忆模块（本地 JSON + 本地 embedding + 隐私优先 Agentic RAG）=====
MEMORY_ENABLED=true
MEMORY_DIR=memory_data
# 最多保留多少条结构化记忆；重要/重复出现的记忆会优先留下
MEMORY_MAX_ITEMS=200
# embedding 默认使用本地哈希向量，不调用第三方 embedding API，避免泄露私密记忆。
# 本机有 Ollama 时可以改成 ollama，并拉取：ollama pull qwen3-embedding:0.6b
MEMORY_EMBEDDING_ENABLED=true
MEMORY_EMBEDDING_PROVIDER=local_hash
MEMORY_EMBEDDING_DIM=256
MEMORY_OLLAMA_BASE_URL=http://127.0.0.1:11434
MEMORY_OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
MEMORY_OLLAMA_TIMEOUT_SECONDS=5
# Agentic RAG 只会在隐私过滤后的候选记忆里调用 DeepSeek 做重排
MEMORY_AGENTIC_RAG_ENABLED=true
MEMORY_RAG_CANDIDATES=12
# Agentic write 会在长期记忆落库前判断 create/update/ignore/delete/confirm
MEMORY_AGENTIC_WRITE_ENABLED=true

# ===== 外部搜索（本地 DeerFlow / OpenClaw）=====
# 只在本地模式可用；GitHub Actions 不能访问本机 DeerFlow/OpenClaw。
EXTERNAL_SEARCH_ENABLED=true
# deerflow: 优先使用本机 DeerFlow；openclaw: 直接走 OpenClaw；auto: DeerFlow 失败后回退。
EXTERNAL_SEARCH_BACKEND=deerflow
EXTERNAL_SEARCH_FALLBACK_OPENCLAW=true
DEERFLOW_BACKEND_DIR=/Users/you/Code/deer-flow/backend
DEERFLOW_PYTHON=/Users/you/Code/deer-flow/backend/.venv/bin/python
DEERFLOW_SEARCH_TIMEOUT_SECONDS=120
# OpenClaw 可作为直接搜索或回退搜索。launchd 可能没有交互 shell 的 PATH；代码会自动兜底查找。
OPENCLAW_CLI=openclaw
# 可选：默认使用 OpenClaw 当前选中的 web.search provider
# OPENCLAW_SEARCH_PROVIDER=tavily
OPENCLAW_SEARCH_LIMIT=5
OPENCLAW_SEARCH_TIMEOUT_SECONDS=45

# ===== 旁听辅助（默认开启，强冷却，避免插嘴）=====
# 非 @ 群聊消息进入旁听队列；聊天静默一段时间后，才可能补一张背景资料卡片。
PASSIVE_ASSIST_ENABLED=true
PASSIVE_ASSIST_QUIET_SECONDS=75
PASSIVE_ASSIST_RECENT_WINDOW_SECONDS=480
PASSIVE_ASSIST_TOPIC_COOLDOWN_SECONDS=1800
PASSIVE_ASSIST_MAX_PER_HOUR=2

# ===== 主动话题（本地长连接，冷场时每天最多主动 @ 一次）=====
PROACTIVE_TOPIC_ENABLED=true
PROACTIVE_TOPIC_MAX_PER_DAY=1
PROACTIVE_TOPIC_QUIET_SECONDS=1800
PROACTIVE_TOPIC_CHECK_INTERVAL_SECONDS=300
PROACTIVE_TOPIC_ACTIVE_START=09:30
PROACTIVE_TOPIC_ACTIVE_END=23:30

# ===== 每日恋爱笔记（默认关闭）=====
LOVE_NOTE_ENABLED=false
LOVE_NOTE_WIKI_TOKEN=wikixxxxxxxxxxxxxxxxxxxx
# 已解析出的 docx token，可不填；填了就不用每次解析 wiki。
LOVE_NOTE_DOC_TOKEN=docxxxxxxxxxxxxxxxxxxxx
LOVE_NOTE_RUN_AT=23:55

# ===== 通话/妙记上下文（默认关闭）=====
# 需要飞书应用具备 minutes:minutes.basic:read 和 minutes:minutes.transcript:export 等权限，
# 且应用身份或用户身份对对应妙记有阅读/导出权限。
CALL_NOTES_ENABLED=false
FEISHU_MINUTE_TOKENS=obcnxxxxxxxxxxxxxxxxxxxx
CALL_NOTES_MAX_CHARS=3000

# ===== GitHub =====
GITHUB_USERNAME=your-github-username
# 可选，填了可以提高 API 速率限制
# GITHUB_TOKEN=ghp_xxx
# 额外追踪的私有仓库，多个用英文逗号分隔
GITHUB_PRIVATE_REPOS=owner/private-repo

# ===== 运行配置 =====
# true = 本地测试，不真正推送飞书
DRY_RUN=true
# 轮询间隔（秒），默认 300 = 5 分钟
POLL_INTERVAL_SECONDS=300
STATUS_NOTIFY_COOLDOWN_SECONDS=300

# ===== 回复体验 =====
# 普通聊天回复使用飞书流式卡片：先发“正在输入...”，再逐步更新内容。
STREAMING_REPLY_ENABLED=true
STREAMING_REPLY_UPDATE_INTERVAL_SECONDS=0.35

# ===== LLM 上下文预算 =====
CONTEXT_MAX_CHARS=6000
CONTEXT_CHAT_MAX_CHARS=2400
CONTEXT_MEMORY_MAX_CHARS=1600
CONTEXT_CALL_NOTES_MAX_CHARS=1600
