# ===== Feishu =====
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_CHAT_ID=oc_xxx
FEISHU_BOT_OPEN_ID=ou_xxx
FEISHU_OWNER_OPEN_ID=ou_xxx
FEISHU_TARGET_OPEN_ID=ou_xxx        # 可选；多人群聊推荐在 profiles/*.json 的 members 里维护

# ===== LLM provider =====
# Agent Plan example:
LLM_API_KEY=ark-xxx
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
LLM_MODEL=glm-5.2
# Legacy DeepSeek variables remain supported when LLM_* is unset.

# ===== Ollama (optional, for embeddings) =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-embedding:0.6b
OLLAMA_VISION_MODEL=qwen2.5vl:3b
# 兼容旧变量名；如果两组都配置，优先使用 OLLAMA_*
MEMORY_OLLAMA_BASE_URL=http://localhost:11434
MEMORY_OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# ===== Image understanding =====
# macOS 默认优先使用本地 Apple Vision OCR；失败后再调用飞书 OCR
LOCAL_OCR_ENABLED=true
LOCAL_OCR_BACKEND=auto
APPLE_VISION_OCR_BINARY=bin/macos-vision-ocr
LOCAL_OCR_TIMEOUT_SECONDS=15
# 飞书 OCR 作为跨平台降级；触发 99991400 后自动冷却
FEISHU_OCR_ENABLED=true
FEISHU_OCR_COOLDOWN_SECONDS=300
LOCAL_VISION_ENABLED=true
# 云端视觉备用，只有本地 Qwen-VL 未配置、超时或失败时调用。
# 这里填控制台生成的 API Key，不要把它提交到仓库。
SENSENOVA_VISION_ENABLED=false
SENSENOVA_API_KEY=
# 兼容旧配置名；新配置请使用 SENSENOVA_API_KEY。
SENSENOVA_API_TOKEN=
SENSENOVA_BASE_URL=https://token.sensenova.cn/v1
SENSENOVA_VISION_MODEL=sensenova-6.7-flash-lite
SENSENOVA_TIMEOUT_SECONDS=90

# ===== GitHub =====
GH_USERNAME=your_username
GH_TOKEN=ghp_xxx
GH_PRIVATE_REPOS=owner/repo1,owner/repo2

# ===== Profile =====
PROFILE_ID=default
PROFILES_DIR=.

# ===== Behavior =====
DRY_RUN=true
# 流式回复走飞书 CardKit 流式卡片接口，需在应用后台开通 cardkit:card:write 权限；
# 未开通时自动降级为「发文本消息 + 编辑」
STREAMING_REPLY_ENABLED=true
STREAMING_REPLY_UPDATE_INTERVAL_SECONDS=0.35
MEMORY_ENABLED=true
MEMORY_CONFIRMATION_ENABLED=true
# 可选：OceanBase/MySQL 记忆后端。支持 jdbc:mysql://127.0.0.1:2881/companion_memory 这种写法；
# 不配置时继续使用 memory_data/<PROFILE_ID>/memories.json
MEMORY_DATABASE_DSN=
# 必须与 embedding 模型输出维度一致；qwen3-embedding:0.6b 为 1024 维
MEMORY_EMBEDDING_DIMENSION=1024
# 是否把聊天归档表作为只读长期聊天记忆参与检索
MEMORY_INCLUDE_CHAT_ARCHIVE=false
# 聊天归档可见性：owner_only / public_to_target / private
MEMORY_CHAT_ARCHIVE_VISIBILITY=owner_only
# 聊天归档表/列名（接自己的聊天库时按 schema 改；默认值仅为示例）
MEMORY_CHAT_ARCHIVE_TABLE=chat_message_chunks
MEMORY_CHAT_ARCHIVE_TEXT_COLUMN=chunk_text
MEMORY_CHAT_ARCHIVE_TIME_COLUMN=end_time
# 是否把图片/OCR 归档表作为只读长期图片记忆参与检索
MEMORY_INCLUDE_MEDIA_ARCHIVE=false
# 图片归档可见性：owner_only / public_to_target / private
MEMORY_MEDIA_ARCHIVE_VISIBILITY=owner_only
# 图片归档表/列名（接自己的图片索引表时按 schema 改；默认值仅为示例）
MEMORY_MEDIA_ARCHIVE_TABLE=media_assets
MEMORY_MEDIA_OCR_COLUMN=ocr_text
MEMORY_MEDIA_CAPTION_COLUMN=caption
MEMORY_MEDIA_TIME_COLUMN=sent_at
MEMORY_MEDIA_SENDER_COLUMN=sender
MEMORY_MEDIA_FILE_PATH_COLUMN=file_path
MEMORY_MEDIA_MSGID_COLUMN=msgid
# 可选：归档脚本可以为失效本地文件写入 invalid；没有此列时仍会在进程内过滤
MEMORY_MEDIA_STATUS_COLUMN=path_status
# 数据库里保存相对图片路径时填写根目录
MEMORY_MEDIA_ROOT=
# 机器人接收的新图片会复制到这个私有、内容寻址的目录；数据库只保存相对路径。
MEMORY_MEDIA_VAULT=memory_data/default/media
# 命中图片记忆时是否把最相关的一张图也发回飞书
MEMORY_MEDIA_SEND_IMAGE=true

# ===== 恋爱笔记增量评论（可选） =====
LOVE_NOTE_ENABLED=false
LOVE_NOTE_DOC_TOKEN=
LOVE_NOTE_WIKI_TOKEN=
LOVE_NOTE_CHECK_INTERVAL_SECONDS=300
LOVE_NOTE_MAX_DAILY_COMMENTS=2

# ===== Polling =====
POLL_INTERVAL_SECONDS=300
